# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*

# Exclude all variable files that might contain secrets (Good practice)
*.tfvars
*.tfvars.json
.env                  # <-- ADICIONE ISSO para proteger suas credenciais locais

# Lock file (Evita conflitos de concorrência local no repositório)
.terraform.lock.hcl   # <-- ADICIONE ISSO para limpar seu repositório de metadados locais

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configurations
.terraformrc
terraform.rc